{
  "$schema": "https://phenix.local/schemas/tend.schema.json",
  "version": 1,
  "node": {
    "id": "root",
    "description": "Root workspace code quality and maintenance checks",
    "tags": ["workspace", "foundation"],
    "context": {
      "workdir": "."
    },
    "tasks": [
      {
        "id": "tend-validate-profiles",
        "description": "Validate all tend profiles and configuration",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual"],
        "tags": ["tend", "validate"],
        "command": ["tend", "validate", "--profiles"],
        "expect": { "status": 0 }
      },
      {
        "id": "nixfmt-check",
        "description": "Check root Nix files are formatted correctly",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "format"],
        "command": ["bash", "-c", "find . -maxdepth 1 -name '*.nix' -print0 | xargs -0 -r nixfmt --check"],
        "expect": { "status": 0 }
      },
      {
        "id": "statix-check",
        "description": "Lint root Nix files with statix (skipping submodules)",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "lint"],
        "command": ["statix", "check", "--ignore", "flakes/**", "--ignore", ".git/**"],
        "expect": { "status": 0 }
      },
      {
        "id": "deadnix-check",
        "description": "Find and report dead Nix code in root files",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "cleanup"],
        "command": ["bash", "-c", "find . -maxdepth 1 -name '*.nix' -print0 | xargs -0 -r deadnix --fail --no-lambda-arg --no-lambda-pattern-names"],
        "expect": { "status": 0 }
      },
      {
        "id": "submodule-tend-json-check",
        "description": "Verify each submodule has a .tend.json with appropriate checks",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["pre-push", "manual"],
        "tags": ["submodule", "consistency"],
        "command": ["bash", "-c", "for dir in flakes/*/*/; do if [ -f \"$dir/flake.nix\" ] && [ ! -f \"$dir/.tend.json\" ]; then echo \"MISSING: $dir.tend.json\"; exit 1; fi; done; echo \"All submodules have .tend.json\""],
        "expect": { "status": 0 }
      },
      {
        "id": "nix-flake-check",
        "description": "Full Nix flake evaluation check",
        "phase": "verify",
        "kind": "command",
        "command": ["nix", "flake", "check"],
        "profiles": ["manual"],
        "tags": ["nix", "full"],
        "sandbox_safe": false,
        "mutates": false,
        "interactive": false
      },
      {
        "id": "nixfmt-fix",
        "description": "Auto-format all Nix files",
        "phase": "fix",
        "kind": "command",
        "command": ["bash", "-c", "find . -maxdepth 1 -name '*.nix' -print0 | xargs -0 -r nixfmt"],
        "profiles": ["fix"],
        "tags": ["nix", "format", "fix"],
        "sandbox_safe": false,
        "mutates": true
      },
      {
        "id": "statix-fix",
        "description": "Auto-fix statix warnings where safe",
        "phase": "fix",
        "kind": "command",
        "command": ["statix", "fix"],
        "profiles": ["fix"],
        "tags": ["nix", "lint", "fix"],
        "sandbox_safe": false,
        "mutates": true
      }
    ]
  }
}
