{
  "$schema": "https://phenix.local/schemas/tend.schema.json",
  "version": 1,
  "node": {
    "id": "root",
    "description": "Root workspace code quality and maintenance checks",
    "tags": ["workspace", "foundation"],
    "context": {
      "workdir": "."
    },
    "tasks": [
      {
        "id": "tend-validate-profiles",
        "description": "Validate all tend profiles and configuration",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual"],
        "tags": ["tend", "validate"],
        "command": ["bash", "-c", "if command -v tend >/dev/null 2>&1; then tend validate --profiles; else nix run .#tend -- validate --profiles; fi"],
        "expect": { "status": 0 }
      },
      {
        "id": "nixfmt-check",
        "description": "Check root Nix files are formatted correctly",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "format"],
        "command": ["bash", "-c", "find . -maxdepth 1 -name '*.nix' -print0 | xargs -0 -r nixfmt --check"],
        "expect": { "status": 0 }
      },
      {
        "id": "statix-check",
        "description": "Lint root Nix files with statix (skipping submodules)",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "lint"],
        "command": ["statix", "check", "--ignore", "flakes/**", "--ignore", ".git/**"],
        "expect": { "status": 0 }
      },
      {
        "id": "deadnix-check",
        "description": "Find and report dead Nix code in root files",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "cleanup"],
        "command": ["bash", "-c", "find . -maxdepth 1 -name '*.nix' -print0 | xargs -0 -r deadnix --fail --no-lambda-arg --no-lambda-pattern-names"],
        "expect": { "status": 0 }
      },
      {
        "id": "json-validate-check",
        "description": "Validate JSON files in the root workspace",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["json", "format"],
        "command": ["bash", "-c", "files=$(find . -path './flakes' -prune -o -path './.git' -prune -o -name '*.json' -type f -print); if [ -z \"$files\" ]; then echo 'No JSON files'; exit 0; fi; printf '%s\n' \"$files\" | xargs jq -e . >/dev/null"],
        "expect": { "status": 0 }
      },
      {
        "id": "qml-format-check",
        "description": "Format-check QML files when QML files and qmlformat are available",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["pre-push", "manual"],
        "tags": ["qml", "format"],
        "command": ["bash", "-c", "files=$(find . -path './flakes' -prune -o -path './.git' -prune -o -name '*.qml' -type f -print); if [ -z \"$files\" ]; then echo 'No QML files'; exit 0; fi; if ! command -v qmlformat >/dev/null 2>&1; then echo 'qmlformat unavailable; skipping'; exit 0; fi; printf '%s\n' \"$files\" | xargs qmlformat --check"],
        "expect": { "status": 0 }
      },
      {
        "id": "lua-format-check",
        "description": "Format-check Lua files when Lua files and stylua are available",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["pre-push", "manual"],
        "tags": ["lua", "format"],
        "command": ["bash", "-c", "files=$(find . -path './flakes' -prune -o -path './.git' -prune -o -name '*.lua' -type f -print); if [ -z \"$files\" ]; then echo 'No Lua files'; exit 0; fi; if ! command -v stylua >/dev/null 2>&1; then echo 'stylua unavailable; skipping'; exit 0; fi; printf '%s\n' \"$files\" | xargs stylua --check"],
        "expect": { "status": 0 }
      },
      {
        "id": "stitch-topology-check",
        "description": "Validate workspace DAG topology via stitch graph verify",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["pre-push", "manual"],
        "tags": ["stitch", "topology", "workspace"],
        "command": ["bash", "-c", "if command -v stitch >/dev/null 2>&1; then stitch graph verify; else echo 'stitch unavailable; skipping topology check'; exit 0; fi"],
        "expect": { "status": 0 }
      },
      {
        "id": "mix-format-check",
        "description": "Run Mix formatter check when an Elixir project is present",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["pre-push", "manual"],
        "tags": ["elixir", "format"],
        "command": ["bash", "-c", "if [ ! -f mix.exs ]; then echo 'No mix.exs'; exit 0; fi; if ! command -v mix >/dev/null 2>&1; then echo 'mix unavailable; skipping'; exit 0; fi; mix format --check-formatted"],
        "expect": { "status": 0 }
      },
      {
        "id": "nix-flake-check",
        "description": "Full Nix flake evaluation check",
        "phase": "verify",
        "kind": "command",
        "command": ["nix", "flake", "check"],
        "profiles": ["manual"],
        "tags": ["nix", "full"],
        "sandbox_safe": false,
        "mutates": false,
        "interactive": false
      },
      {
        "id": "nixfmt-fix",
        "description": "Auto-format all Nix files",
        "phase": "fix",
        "kind": "command",
        "command": ["bash", "-c", "find . -maxdepth 1 -name '*.nix' -print0 | xargs -0 -r nixfmt"],
        "profiles": ["fix"],
        "tags": ["nix", "format", "fix"],
        "sandbox_safe": false,
        "mutates": true
      },
      {
        "id": "statix-fix",
        "description": "Auto-fix statix warnings where safe",
        "phase": "fix",
        "kind": "command",
        "command": ["statix", "fix"],
        "profiles": ["fix"],
        "tags": ["nix", "lint", "fix"],
        "sandbox_safe": false,
        "mutates": true
      }
    ]
  }
}
