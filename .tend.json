{
  "profiles": {
    "git-hook": {
      "phase": "verify",
      "selection": "staged",
      "tasks": [
        "nixfmt-check",
        "statix-check",
        "deadnix-check",
        "json-validate-check",
        "docs-presence-check",
        "git-jj-policy-check"
      ],
      "contexts": [
        "local"
      ]
    },
    "pre-push": {
      "phase": "verify",
      "selection": "full",
      "tasks": [
        "nixfmt-check",
        "statix-check",
        "deadnix-check",
        "json-validate-check",
        "qml-format-check",
        "lua-format-check",
        "docs-presence-check",
        "git-jj-policy-check",
        "stitch-locked-graph-check",
        "nix-flake-check",
        "nixos-toplevel-eval"
      ],
      "contexts": [
        "local"
      ]
    },
    "manual": {
      "phase": "verify",
      "selection": "full",
      "tasks": [
        "nixfmt-check",
        "statix-check",
        "deadnix-check",
        "json-validate-check",
        "qml-format-check",
        "lua-format-check",
        "docs-presence-check",
        "git-jj-policy-check",
        "stitch-locked-graph-check",
        "nix-flake-check",
        "nixos-toplevel-eval"
      ],
      "contexts": [
        "local"
      ]
    },
    "ci": {
      "phase": "verify",
      "selection": "git-range",
      "tasks": [
        "nixfmt-check",
        "statix-check",
        "deadnix-check",
        "json-validate-check",
        "qml-format-check",
        "lua-format-check",
        "docs-presence-check",
        "git-jj-policy-check",
        "stitch-locked-graph-check",
        "nix-flake-check",
        "nixos-toplevel-eval"
      ],
      "contexts": [
        "ci"
      ]
    },
    "nix-check": {
      "phase": "verify",
      "selection": "full",
      "tasks": [
        "nixfmt-check",
        "statix-check",
        "deadnix-check",
        "json-validate-check",
        "docs-presence-check",
        "git-jj-policy-check",
        "stitch-locked-graph-check"
      ],
      "contexts": [
        "nix-sandbox"
      ]
    },
    "fix": {
      "phase": "fix",
      "selection": "staged",
      "tasks": [
        "nixfmt-fix",
        "statix-fix"
      ],
      "contexts": [
        "local"
      ]
    },
    "setup": {
      "phase": "setup",
      "selection": "full",
      "tasks": [
        "hooks-plan",
        "hooks-install"
      ],
      "contexts": [
        "local"
      ]
    }
  },
  "contexts": {
    "local": {
      "implementation": "local",
      "allow_mutation": true,
      "allow_interactive": false,
      "allow_network": true,
      "require_sandbox_safe": false
    },
    "ci": {
      "implementation": "local",
      "allow_mutation": false,
      "allow_interactive": false,
      "allow_network": true,
      "require_sandbox_safe": false
    },
    "nix-sandbox": {
      "implementation": "sandbox",
      "allow_mutation": false,
      "allow_interactive": false,
      "allow_network": false,
      "require_sandbox_safe": true
    }
  },
  "node": {
    "id": "root",
    "description": "Verify the Phenix root workspace and locked dependency graph",
    "tasks": [
      {
        "id": "nixfmt-check",
        "description": "Check root Nix formatting",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": [
              "*.nix"
            ]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "nixfmt",
              "--check"
            ],
            "file_args": "matched",
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "statix-check",
        "description": "Lint root Nix expressions",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": [
              "*.nix"
            ]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "statix",
              "check",
              "--ignore",
              ".git/**"
            ],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "deadnix-check",
        "description": "Reject dead root Nix code",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": [
              "*.nix"
            ]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "deadnix",
              "--fail",
              "--no-lambda-arg",
              "--no-lambda-pattern-names"
            ],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "json-validate-check",
        "description": "Parse changed workspace JSON files",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": [
              "*.json",
              "**/*.json"
            ]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "bash",
              "-c",
              "for file in \"$@\"; do jq -e . \"$file\" >/dev/null; done",
              "--"
            ],
            "file_args": "matched",
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "qml-format-check",
        "description": "Check changed QML formatting when qmlformat is available",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": [
              "**/*.qml"
            ]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "bash",
              "-c",
              "if ! command -v qmlformat >/dev/null; then echo 'qmlformat unavailable; skipping'; exit 0; fi; qmlformat --check \"$@\"",
              "--"
            ],
            "file_args": "matched",
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "lua-format-check",
        "description": "Check changed Lua formatting when Stylua is available",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": [
              "**/*.lua"
            ]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "bash",
              "-c",
              "if ! command -v stylua >/dev/null; then echo 'stylua unavailable; skipping'; exit 0; fi; stylua --check \"$@\"",
              "--"
            ],
            "file_args": "matched",
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "docs-presence-check",
        "description": "Require the root workflow documentation and contracts",
        "phase": "verify",
        "always": true,
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "bash",
              "-c",
              "missing=0; for file in ROADMAP.md docs/workflow/git-jj-policy.md docs/workflow/workspace-state.md AGENTS.md flake.nix flake.lock .tend.json; do if [[ ! -f \"$file\" ]]; then echo \"MISSING: $file\"; missing=1; fi; done; exit \"$missing\""
            ],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "git-jj-policy-check",
        "description": "Require the documented Git/Jujutsu policy",
        "phase": "verify",
        "always": true,
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "test",
              "-f",
              "docs/workflow/git-jj-policy.md"
            ],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "stitch-locked-graph-check",
        "description": "Validate the strict lock-derived workspace graph",
        "phase": "verify",
        "always": true,
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "stitch",
              "graph",
              "verify",
              "--workspace",
              ".",
              "--source",
              "locks",
              "--strict"
            ],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "nix-flake-check",
        "description": "Run the complete root flake gate",
        "phase": "verify",
        "always": true,
        "implementations": {
          "local": {
            "kind": "command",
            "command": [
              "nix",
              "flake",
              "check",
              "--print-build-logs",
              "--keep-going",
              "--accept-flake-config"
            ],
            "network": true,
            "sandbox_safe": false
          }
        }
      },
      {
        "id": "nixos-toplevel-eval",
        "description": "Force both aggregate NixOS toplevel derivations without Home Manager package-set warnings",
        "phase": "verify",
        "always": true,
        "implementations": {
          "local": {
            "kind": "command",
            "command": [
              "bash",
              "-c",
              "set -euo pipefail; for host in matthisk-laptop-phenix matthisk-desktop-phenix; do log=\"$(mktemp)\"; if ! nix eval --raw \".#nixosConfigurations.${host}.config.system.build.toplevel.drvPath\" >/dev/null 2>\"$log\"; then cat \"$log\"; exit 1; fi; cat \"$log\"; if grep -Fq \"home-manager.useGlobalPkgs\" \"$log\"; then echo \"Home Manager global package-set warning returned for $host\" >&2; exit 1; fi; rm -f \"$log\"; done"
            ],
            "network": true,
            "sandbox_safe": false
          }
        }
      },
      {
        "id": "nixfmt-fix",
        "description": "Format changed root Nix files",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": [
              "*.nix"
            ]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "nixfmt"
            ],
            "file_args": "matched",
            "mutates": true
          }
        }
      },
      {
        "id": "statix-fix",
        "description": "Apply safe Statix fixes",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": [
              "*.nix"
            ]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": [
              "statix",
              "fix"
            ],
            "mutates": true
          }
        }
      },
      {
        "id": "hooks-plan",
        "description": "Preview workspace hook installation",
        "phase": "setup",
        "always": true,
        "implementations": {
          "local": {
            "kind": "command",
            "command": [
              "stitch",
              "hooks",
              "plan",
              "--all"
            ],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "hooks-install",
        "description": "Install workspace hooks",
        "phase": "setup",
        "always": true,
        "implementations": {
          "local": {
            "kind": "command",
            "command": [
              "stitch",
              "hooks",
              "install",
              "--all"
            ],
            "mutates": true,
            "sandbox_safe": false
          }
        }
      }
    ]
  }
}
