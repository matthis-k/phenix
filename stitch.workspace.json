{
  "version": 1,
  "nodes": {
    "phenix-pins": {
      "kind": "pins",
      "layer": 0
    },
    "phenix-packages": {
      "kind": "packageProvider",
      "layer": 1
    },
    "phenix-shell": {
      "kind": "shellProvider",
      "layer": 1
    },
    "phenix-tools": {
      "kind": "toolProvider",
      "layer": 1
    },
    "phenix-de": {
      "kind": "desktopProvider",
      "layer": 2
    },
    "phenix-nvim": {
      "kind": "desktopProvider",
      "layer": 2
    },
    "phenix-hosts": {
      "kind": "hostConsumer",
      "layer": 3
    },
    "phenix": {
      "kind": "workspaceRoot",
      "layer": 4,
      "root": true
    }
  },
  "rules": {
    "forbidCycles": true,
    "forbidRootProviderRole": true,
    "forbidProviderDependsOnConsumer": true,
    "requireRootUltimateConsumer": true
  }
}
