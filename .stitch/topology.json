{
  "version": 1,
  "workspace": "phenix",
  "root": ".",
  "repos": [
    {
      "name": "phenix-pins",
      "role": "pins",
      "layer": 0,
      "path": "flakes/00-pins/phenix-pins",
      "url": "git@github.com:matthis-k/phenix-pins.git"
    },
    {
      "name": "phenix-tend",
      "role": "producer",
      "layer": 2,
      "path": "flakes/02-producers/phenix-tend",
      "url": "https://github.com/matthis-k/phenix-tend.git"
    },
    {
      "name": "phenix-stitch",
      "role": "producer",
      "layer": 2,
      "path": "flakes/02-producers/phenix-stitch",
      "url": "https://github.com/matthis-k/phenix-stitch.git"
    },
    {
      "name": "phenix-nvim",
      "role": "producer",
      "layer": 2,
      "path": "flakes/02-producers/phenix-nvim",
      "url": "git@github.com:matthis-k/phenix-nvim.git"
    },
    {
      "name": "phenix-opencode",
      "role": "integration",
      "layer": 3,
      "path": "flakes/03-integrations/phenix-opencode",
      "url": "git@github.com:matthis-k/phenix-opencode.git"
    },
    {
      "name": "phenix-packages",
      "role": "pkgs-aggregator",
      "layer": 4,
      "path": "flakes/04-pkgs/phenix-packages",
      "url": "git@github.com:matthis-k/phenix-packages.git"
    },
    {
      "name": "phenix-de",
      "role": "consumer",
      "layer": 5,
      "path": "flakes/05-consumers/phenix-de",
      "url": "git@github.com:matthis-k/phenix-de.git"
    },
    {
      "name": "phenix-hosts",
      "role": "consumer",
      "layer": 5,
      "path": "flakes/05-consumers/phenix-hosts",
      "url": "git@github.com:matthis-k/phenix-hosts.git"
    },
    {
      "name": "phenix",
      "role": "root",
      "layer": 6,
      "path": "."
    }
  ],
  "rules": {
    "forbidCycles": true,
    "forbidRootDependency": true,
    "forbidSameLayerInternalInputs": true,
    "forbidProducerDependsOnProducer": true,
    "forbidProducerDependsOnPkgsAggregator": true,
    "requirePathLayerMatchesConfiguredLayer": true
  }
}
